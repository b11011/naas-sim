# Copy to .env (gitignored) or export in your shell. All values shown are defaults.

# --- Simulator (python -m simulator) ---
NAAS_SIM_HOST=127.0.0.1
NAAS_SIM_PORT=8080
NAAS_SIM_CLIENT_ID=naas-lab-client
NAAS_SIM_CLIENT_SECRET=naas-lab-secret
NAAS_SIM_DELAY_SECONDS=10          # async transition window; set 2 for fast dev loops
NAAS_SIM_QUOTE_TTL_SECONDS=900     # Internet On-Demand quote validity (real: 15 min)
NAAS_SIM_DAILY_ORDER_LIMIT=24      # order quota per customer per GMT day (real: 24)
NAAS_SIM_TOKEN_TTL_SECONDS=3600

# --- Example clients + NetBox integration ---
NAAS_BASE_URL=http://localhost:8080
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=                       # NetBox API token; v2 format: nbt_<key>.<secret>
SELF_URL=http://localhost:8090      # middleware callback URL as reachable FROM the simulator
